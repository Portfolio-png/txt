NODE_ENV=production
PORT=18080
DB_PATH=./data/paper.db
PAPER_JWT_SECRET=replace-with-a-long-random-secret
PAPER_SUPER_ADMIN_EMAIL=owner@example.com
PAPER_SUPER_ADMIN_PASSWORD=replace-with-a-strong-temporary-password
PAPER_SUPER_ADMIN_NAME=Super Admin
PAPER_CORS_ORIGIN=
PAPER_SEED_DEMO_DATA_ON_BOOT=false
PAPER_JWT_TTL_SECONDS=43200
PAPER_LOGIN_MAX_ATTEMPTS=5
PAPER_LOGIN_WINDOW_MINUTES=15
PAPER_LOGIN_LOCKOUT_MINUTES=15
PAPER_AUTH_EVENTS_RETENTION_DAYS=365
PAPER_REVOKED_SESSIONS_RETENTION_DAYS=90
PAPER_BACKUP_DIR=
PAPER_S3_REGION=us-east-1
PAPER_S3_BUCKET_NAME=
# Optional local S3-compatible override for development only.
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=true
# Optional local credentials when not running on EC2/IAM-backed infrastructure.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Test/local-only escape hatch. Leave false/unset in production.
S3_SKIP_OBJECT_VERIFY=false
